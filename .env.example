# ==============================
# WeWantHappy 환경변수 예시
# 이 파일을 .env로 복사하고 실제 값으로 교체하세요.
# ==============================

# ─── 데이터베이스 ───────────────────────────────────────
# docker-compose 기본값과 일치
DATABASE_URL=postgresql+asyncpg://wwp:wwplocal@localhost/wewanthappy
DB_PASSWORD=wwplocal

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Telegram Bot API ───────────────────────────────────
# BotFather에서 /newbot으로 생성
TELEGRAM_BOT_TOKEN=

# ─── Telegram MTProto ─────────────────────────────────
# https://my.telegram.org → API development tools에서 발급
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890

# ─── Firebase / FCM ─────────────────────────────────────
# Firebase 콘솔 → 프로젝트 설정 → 서비스 계정에서 JSON 다운로드
FCM_PROJECT_ID=wewanthappy-prod
GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json

# FCM 웹 푸시 (프론트엔드 .env.local에도 추가)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=wewanthappy-prod
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ─── 보안 ────────────────────────────────────────────────
# 랜덤 64자 문자열 권장: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-64-char-string

# 개발용 인증 우회 (절대 프로덕션에서 true로 설정 금지)
DISABLE_AUTH=false

# ─── CORS ────────────────────────────────────────────────
# 쉼표 구분, 프로덕션에서는 실제 도메인만 허용
ALLOWED_ORIGINS=http://localhost:3000

# ─── 앱 설정 ─────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ─── 프론트엔드 ──────────────────────────────────────────
# Mapbox (https://account.mapbox.com/access-tokens/)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token-here

# 백엔드 API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Fly.io 배포 ─────────────────────────────────────────
# fly secrets set ... 명령으로 설정 (이 파일에는 빈값 유지)
#
# fly secrets set DATABASE_URL="postgresql+asyncpg://..."
# fly secrets set REDIS_URL="redis://..."
# fly secrets set TELEGRAM_BOT_TOKEN="..."
# fly secrets set GOOGLE_APPLICATION_CREDENTIALS_JSON="$(cat service-account.json)"
# fly secrets set SECRET_KEY="$(openssl rand -hex 32)"
#
FLY_APP_NAME=wewanthappy-backend
FLY_REGION=nrt

# ─── GitHub Actions ──────────────────────────────────────
# GitHub → 저장소 Settings → Secrets에 추가:
#   FLY_API_TOKEN       (fly auth token)
#   NEXT_PUBLIC_MAPBOX_TOKEN
#   NEXT_PUBLIC_FIREBASE_API_KEY
#   NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN
#   NEXT_PUBLIC_FIREBASE_PROJECT_ID
#   NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID
#   NEXT_PUBLIC_FIREBASE_APP_ID
#   NEXT_PUBLIC_FIREBASE_VAPID_KEY
